<style>
:root {
--theme-primary-color: #333333;--theme-secondary-color: #7d7d7d;
--base-font-family: "Roboto", Arial, Helvetica, sans-serif;
}
@media (max-width: 767px) {:root {font-size: 9px; --theme-size: 9px; }}
body {font: 400 1.6rem/1.5 "Roboto", Arial, Helvetica, sans-serif;}
input:not([class]),textarea:not([class]),select:not([class]),select.form-control,.ui-input, .ui-range__input, .ui-textarea,.form-control:not(select),.ui-select,.ui-select select,.personal__order-table-info{
font-family: "Roboto", Arial, Helvetica, sans-serif;}
@media (min-width: 768px) {.personal__order-table {font-family: "Roboto", Arial, Helvetica, sans-serif;}}
@media (max-width: 767px) {.personal__order-table {font-family: "Roboto", Arial, Helvetica, sans-serif;}}
 
/* 333333 7d7d7d    */
@media (max-width: 1199px) {.products__item {height: auto!important;}.products__item-discount,.products__item-action {position: relative;opacity: 1;visibility: visible;transform: translate(0, 0);}}
	
.ui-btn.js-btn-preview {display: none;} 
.header__catalog-link-icon svg, .header__catalog-link-icon svg path, .header__tags-btn svg, .header__tags-btn svg path {
    fill: currentColor !important;
    max-height: 2rem;
    max-width: 2rem;
}

/* Товар */
.sku__slide {
    padding: 0;
}

/*.swiper-horizontal-slides {width: 100%;height: unset;}*/
@media (max-width: 769px) {
    .sku__slide {
        height: auto;
        min-height: 40rem;
    }

    /*.products__item--responsive .products__item-title {*/
    /*    font-size: 1.2rem;*/
    /*}*/

    .products__item-gallery .products__item-image {
        margin: -30px 0;
    }
}

@media (max-width: 480px) {
    .sku__slide {
        min-height: 100vw;
    }
}

.products__item-gallery .products__item-image {
    margin: 0 0 -20px 0;
}

.products__item-title {
    margin: 0;
}

.products__item:hover, .products__item-in:hover {
    z-index: 20;
}

/*.checkout__step-delivery. ui-check__btn-title{
display:none!important;
}*/
.ui-check__btn-text {
    margin: 0 !important;
}

.products-categories__item-title {
    margin: auto;
}

@media (min-width: 1200px) {
    .header__tags-menu > li:nth-child(5) ~ li {
        display: unset;
    }
}

.products__list--grid-4 .products__item-image {
    height: 23.5rem;
}

.products__list--grid-4 .products__item {
    height: 45.1rem;
}

@media (max-width: 767px) {
    .products__item--responsive .products__item-action .ui-btn--primary {
        padding-left: 1.2rem;
        padding-right: 1.2rem;
        height: 4.5rem;
        font-size: 1.5rem;
        letter-spacing: unset;
    }

    .products__item--responsive .products__item-action .ui-btn--view {
        margin-bottom: 1rem;
        width: 4.5rem;
        height: 4.5rem;
    }

    .products__item--responsive .products__item-price {
        font-size: 1.8rem;
        font-weight: 900;
    }
}

@media (max-width: 500px) {
    .header__logo img, .header__logo svg {
        max-height: calc(100% - 4rem);
    }
}

#price_modal {
    display: none;
    position: absolute;
    left: 30%;
    width: 60%;
    top: 170px;
    background: #FFFFFF;
    box-shadow: 0px 0px 4px rgb(0 0 0 / 4%), 0px 4px 32px rgb(0 0 0 / 16%);
    border-radius: 8px;
    text-align: left;
    z-index: 99;
    padding: 24px;
    padding-bottom: 0;
}

#close_cross {
    color: black;
    font-weight: bold;
    position: absolute;
    left: 90%;
    cursor: pointer;
    z-index: 1200;
    border: 1px solid grey;
    padding: 0 7px;
    border-radius: 100%;
}

.sku__price {
    position: relative;
}

.price_style {
    font-weight: bold;
    font-size: 20px;
}

.modalprice_active {
    display: block !important;
}

@media (max-width: 500px) {
    #close_cross {
        left: 85%;
    }

    #price_modal {
        left: 10%;
        width: 80%;
        top: 100px;
    }
}

.icon-help {
    width: 1.8rem;
    height: 1.5rem;
}

.header__catalog-back, .icon-close {
    color: black;
}

.well-sm {
    display: none !important;
}

.products__item-in .products__item-price {
    margin-top: 20px;
    font-weight: bold;
}

@media (min-width: 768px) {
    .modal-dialog {
        max-width: 46rem;
    }

    .ui-btn svg.icon-cart {
        margin-left: 2rem;
    }
}

#notify_submit {
    width: 100%;
    margin-top: 10px;
}

@media (min-width: 1200px) {
    .header__tags-menu > li:nth-child(5) ~ li {
        display: block;
    }

    .header__cart-item-image img {
        height: 100%;
    }
}

.modal-header, .modal-body {
    padding: 0;
}

.modal-header {
    border-bottom: none;
}

.modal-title {
    font-size: 2rem;
    line-height: 1.25;
    font-weight: 500;
}

.modal-header .fancybox-close {
    top: -15px;
    right: -15px;
    color: #343434;
}











/* Phone dropdown */
.phone-wrap {
    position: relative;
    cursor: pointer;
}
.phone-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 1.3rem;
    font-weight: 500;
    color: inherit;
    white-space: nowrap;
    transition: opacity 0.2s;
    line-height: 3.5rem;
    height: 3.5rem;
}
.phone-link:hover {
    opacity: 0.7;
}
.phone-link svg {
    transition: transform 0.2s;
}
.phone-wrap.is-open .phone-link svg {
    transform: rotate(180deg);
}
.phone-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    z-index: 200;
    min-width: 260px;
    overflow: hidden;
    margin-top: 8px;
}
.phone-dropdown::before {
    content: "";
    position: absolute;
    top: -6px;
    right: 20px;
    width: 12px;
    height: 12px;
    background: #fff;
    transform: rotate(45deg);
    box-shadow: -2px -2px 4px rgba(0,0,0,0.05);
}
.phone-flex {
    display: flex;
    flex-direction: column;
}
.phone-soc {
    display: flex;
    flex-direction: column;
    padding: 8px 0;
    border-bottom: 1px solid #f0f0f0;
}
.phone-soc a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    font-size: 1.4rem;
    font-weight: 500;
    color: #333;
    text-decoration: none;
    transition: background 0.15s;
}
.phone-soc a:hover {
    background: #f5f5f5;
    opacity: 1;
}
.phone-soc a svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
}
.phone-telegram:hover { color: #0088cc !important; }
.phone-telegram svg { fill: #0088cc; }
.phone-whatsapp:hover { color: #25D366 !important; }
.phone-whatsapp svg { fill: #25D366; }
.phone-max:hover { color: #168DE2 !important; }
.phone-call {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 14px 20px;
    text-decoration: none;
    color: #333;
    transition: background 0.15s;
}
.phone-call:hover {
    background: #f5f5f5;
    text-decoration: none;
    color: #333;
    opacity: 1;
}
.phone-call-number {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: #333;
}
.phone-call-number small {
    opacity: 1 !important;
    color: inherit !important;
}
.phone-call-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 1.2rem;
    color: #666;
}
.phone-call-btn svg {
    width: 16px;
    height: 16px;
}
@media (max-width: 767px) {
    .phone-dropdown {
        position: fixed;
        top: auto;
        bottom: 0;
        left: 0;
        right: 0;
        border-radius: 16px 16px 0 0;
        margin-top: 0;
        min-width: 100%;
    }
    .phone-dropdown::before { display: none; }
}
 
	
</style>

 
