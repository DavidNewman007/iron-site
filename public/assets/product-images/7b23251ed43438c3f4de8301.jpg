<script>
(function () {
	var rootId = 'seo-slider-wrap-0';
	var sel = '.js-swiper-seo-home-slider-0';
	function initSeoHomeSlider() {
		if (typeof Swiper === 'undefined') {
			return false;
		}
		var root = document.getElementById(rootId);
		if (!root) {
			return false;
		}
		var el = root.querySelector(sel);
		if (!el) {
			return false;
		}
		if (el.swiper) {
			return true;
		}
		new Swiper(el, {
			slidesPerView: 1,
			spaceBetween: 12,
			watchOverflow: true,
			autoHeight: true,
			observer: true,
			observeParents: true,
			autoplay: true,
			loop: true,
			navigation: {
				nextEl: root.querySelector('.js-seo-slider-next-0'),
				prevEl: root.querySelector('.js-seo-slider-prev-0')
			},
			breakpoints: {
				576: {
					slidesPerView: 2,
					spaceBetween: 14
				},
				1200: {
					slidesPerView: 3,
					spaceBetween: 16
				}
			}
		});
		return true;
	}
	function tryInit() {
		if (initSeoHomeSlider()) {
			return;
		}
		var n = 0;
		var t = setInterval(function () {
			if (initSeoHomeSlider() || ++n > 80) {
				clearInterval(t);
			}
		}, 50);
	}
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', tryInit);
	} else {
		tryInit();
	}
	window.addEventListener('load', function () {
		initSeoHomeSlider();
	});
})();
</script>
