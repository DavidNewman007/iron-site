(function() {
    var params = new URLSearchParams(window.location.search);
    var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
    var utm = {};

    keys.forEach(function(key) {
        var val = params.get(key);
        if (val) {
            utm[key] = val;
            document.cookie = key + '=' + encodeURIComponent(val) + '; path=/; max-age=' + (30 * 24 * 3600);
        }
    });

    if (Object.keys(utm).length) {
        fetch('index.php?route=extension/module/utm', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(utm)
        });
    }
})();





// Phone dropdown toggle
$(document).on('click', '.phone-wrap .phone-link', function(e) {
  e.preventDefault();
  e.stopPropagation();
  var wrap = $(this).closest('.phone-wrap');
  wrap.toggleClass('is-open');
  wrap.find('.phone-dropdown').stop().fadeToggle(200);
});
$(document).on('click', '.phone-dropdown a', function(e) {
  e.stopPropagation();
});
$(document).on('click', function() {
  $('.phone-wrap').removeClass('is-open');
  $('.phone-dropdown').stop().fadeOut(200);
});

// Mango-office opacity fix (показать номер полностью)
(function(){
  var s=document.createElement('style');
  s.textContent='.header__phone small,.header__call-btn small,.header__nav-support-link small,.footer__support-link small,.footer__support-phones small,.phone-call-number small,.phone-link small{opacity:1!important}';
  document.head.appendChild(s);
  var fixPhone=function(){document.querySelectorAll('.header__phone small,.header__nav-support-link small,.footer__support-link small,.phone-call-number small,.phone-link small').forEach(function(e){e.style.setProperty("opacity","1","important")});};
  var o=new MutationObserver(fixPhone);
  if(document.body){o.observe(document.body,{childList:true,subtree:true,attributes:true,attributeFilter:["style"]});}
  else{document.addEventListener('DOMContentLoaded',function(){o.observe(document.body,{childList:true,subtree:true,attributes:true,attributeFilter:["style"]});});}
  setInterval(fixPhone,500);
  setTimeout(function(){o.disconnect();},15000);
})();
</script>
 


 
